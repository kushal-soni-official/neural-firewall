# .gitignore — Neural Firewall
# Generated for Python + Windows environment

# Environment & secrets — CRITICAL: never commit these
.env
.env.*
*.env

# Virtual environment
.venv/
venv/
env/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.pycache

# Testing cache
.pytest_cache/
.coverage
htmlcov/

# SQLite databases — contain session data
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# Build artifacts
dist/
build/
*.egg-info/

# IDE files
.vscode/
.idea/
*.suo
*.user

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Cloud deployment temp files
.gcloudignore
